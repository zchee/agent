{
  "$schema": "https://raw.githubusercontent.com/google-gemini/gemini-cli/refs/heads/main/schemas/settings.schema.json",
  "mcpServers": {
    "sequential-thinking": {
      "command": "sequential-thinking"
    },
    "filesystem": {
      "command": "rust-mcp-filesystem",
      "args": [
        "--allow-write",
        "/Users/zchee/go/src",
        "/Users/zchee/src"
      ]
    },
    "gcp-developer-knowledge": {
      "httpUrl": "https://developerknowledge.googleapis.com/mcp",
      "authProviderType": "google_credentials",
      "oauth": {
        "scopes": [
          "https://www.googleapis.com/auth/cloud-platform"
        ]
      },
      "timeout": 30000,
      "headers": {
        "x-goog-user-project": "gaudiy-develop-tokyo"
      }
    },
    "gcp-cloud-run": {
      "httpUrl": "https://run.googleapis.com/mcp",
      "authProviderType": "google_credentials",
      "oauth": {
        "scopes": [
          "https://www.googleapis.com/auth/cloud-platform"
        ]
      },
      "timeout": 30000,
      "headers": {
        "x-goog-user-project": "gaudiy-develop-tokyo"
      }
    },
    "gcp-cloud-logging": {
      "httpUrl": "https://logging.googleapis.com/mcp",
      "authProviderType": "google_credentials",
      "oauth": {
        "scopes": [
          "https://www.googleapis.com/auth/cloud-platform"
        ]
      },
      "timeout": 30000,
      "headers": {
        "x-goog-user-project": "gaudiy-develop-tokyo"
      }
    },
    "gcp-cloud-monitoring": {
      "httpUrl": "https://monitoring.googleapis.com/mcp",
      "authProviderType": "google_credentials",
      "oauth": {
        "scopes": [
          "https://www.googleapis.com/auth/cloud-platform"
        ]
      },
      "timeout": 30000,
      "headers": {
        "x-goog-user-project": "gaudiy-develop-tokyo"
      }
    },
    "gcp-resource-manager": {
      "httpUrl": "https://cloudresourcemanager.googleapis.com/mcp",
      "authProviderType": "google_credentials",
      "oauth": {
        "scopes": [
          "https://www.googleapis.com/auth/cloud-platform"
        ]
      },
      "timeout": 30000,
      "headers": {
        "x-goog-user-project": "gaudiy-develop-tokyo"
      }
    },
    "gcp-spanner": {
      "httpUrl": "https://spanner.googleapis.com/mcp",
      "authProviderType": "google_credentials",
      "oauth": {
        "scopes": [
          "https://www.googleapis.com/auth/cloud-platform"
        ]
      },
      "timeout": 30000,
      "headers": {
        "x-goog-user-project": "gaudiy-develop-tokyo"
      }
    },
    "gcp-vertexai-search": {
      "httpUrl": "https://discoveryengine.googleapis.com/mcp",
      "authProviderType": "google_credentials",
      "oauth": {
        "scopes": [
          "https://www.googleapis.com/auth/cloud-platform"
        ]
      },
      "timeout": 30000,
      "headers": {
        "x-goog-user-project": "gaudiy-develop-tokyo"
      }
    },
    "gopls": {
      "command": "gopls",
      "args": [
        "mcp"
      ]
    },
    "pencil": {
      "command": "/Users/zchee/.vscode-insiders/extensions/highagency.pencildev-0.6.30/out/mcp-server-darwin-arm64",
      "args": [
        "--app",
        "visual_studio_code_-_insiders"
      ],
      "env": {}
    }
  },
  "general": {
    "preferredEditor": "neovim",
    "vimMode": false,
    "checkpointing": {
      "enabled": true
    },
    "retryFetchErrors": true,
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d"
    },
    "enableAutoUpdate": false,
    "enableAutoUpdateNotification": false,
    "defaultApprovalMode": "default",
    "devtools": true,
    "enableNotifications": true
  },
  "output": {
    "format": "text"
  },
  "ui": {
    "theme": "GitHub",
    "hideWindowTitle": false,
    "showStatusInTitle": true,
    "hideTips": false,
    "hideBanner": true,
    "hideContextSummary": false,
    "footer": {
      "hideCWD": false,
      "hideSandboxStatus": false,
      "hideModelInfo": false,
      "hideContextPercentage": false,
      "items": [
        "workspace",
        "git-branch",
        "sandbox",
        "model-name",
        "context-used",
        "quota",
        "memory-usage"
      ]
    },
    "hideFooter": false,
    "showMemoryUsage": true,
    "showLineNumbers": true,
    "showCitations": true,
    "showModelInfoInChat": true,
    "useAlternateBuffer": true,
    "incrementalRendering": true,
    "inlineThinkingMode": "full"
  },
  "ide": {
    "enabled": true
  },
  "privacy": {
    "usageStatisticsEnabled": false
  },
  "context": {
    "fileName": [
      "AGENTS.md",
      "GEMINI.md"
    ],
    "loadMemoryFromIncludeDirectories": true,
    "fileFiltering": {
      "respectGitIgnore": false,
      "respectGeminiIgnore": true,
      "enableRecursiveFileSearch": true,
      "enableFuzzySearch": true
    }
  },
  "tools": {
    "shell": {
      "enableInteractiveShell": true,
      "pager": "cat",
      "showColor": true,
      "inactivityTimeout": 300
    }
  },
  "useWriteTodos": true,
  "advanced": {
    "autoConfigureMemory": true,
    "excludedEnvVars": [
      "DEBUG",
      "DEBUG_MODE"
    ]
  },
  "experimental": {
    "directWebFetch": true,
    "extensionConfig": true,
    "extensionManagement": true,
    "enableAgents": true,
    "extensionReloading": true,
    "jitContext": true,
    "useOSC52Copy": true,
    "useOSC52Paste": true,
    "plan": true,
    "modelSteering": true,
    "extensionRegistry": true,
    "taskTracker": true
  },
  "security": {
    "enablePermanentToolApproval": true,
    "auth": {
      "selectedType": "vertex-ai"
    }
  },
  "model": {
    "name": "gemini-3.1-pro-preview"
  }
}
