  "general": {
    "preferredEditor": "neovim",
    "vimMode": false,
    "checkpointing": {
      "enabled": true
    },
    "retryFetchErrors": true,
    "sessionRetention": {
      "enabled": false,
      "maxAge": "30d"
    },
    "enableAutoUpdate": false,
    "enableAutoUpdateNotification": false,
    "defaultApprovalMode": "auto_edit",
    "devtools": true,
    "enableNotifications": true,
    "topicUpdateNarration": true,
    "plan": {
      "enabled": true
    },
    "notificationMethod": "auto"
  },
  "ui": {
    "theme": "GitHub",
    "hideWindowTitle": false,
    "showStatusInTitle": true,
    "hideTips": false,
    "hideBanner": false,
    "hideContextSummary": false,
    "footer": {
      "hideCWD": false,
      "hideSandboxStatus": false,
      "hideModelInfo": false,
      "hideContextPercentage": false,
      "items": [
        "workspace",
        "git-branch",
        "sandbox",
        "model-name",
        "context-used",
        "quota",
        "memory-usage",
        "code-changes",
        "token-count",
        "session-id"
      ]
    },
    "hideFooter": false,
    "showMemoryUsage": true,
    "showLineNumbers": false,
    "showCitations": true,
    "showModelInfoInChat": true,
    "useAlternateBuffer": false,
    "incrementalRendering": true,
    "inlineThinkingMode": "full",
    "errorVerbosity": "full",
    "loadingPhrases": "off",
    "terminalBuffer": true
  },
  "context": {
    "fileName": [
      "AGENTS.md",
      "GEMINI.md"
    ],
    "loadMemoryFromIncludeDirectories": true,
    "fileFiltering": {
      "enableFileWatcher": true,
      "enableFuzzySearch": true,
      "enableRecursiveFileSearch": true,
      "respectGeminiIgnore": true,
      "respectGitIgnore": true
    }
  },
  "tools": {
    "shell": {
      "enableInteractiveShell": true,
      "pager": "cat",
      "showColor": true,
      "inactivityTimeout": 300
    }
  },
  "agents": {
    "browser": {
      "blockFileUploads": false,
      "confirmSensitiveActions": true
    }
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    },
    "environmentVariableRedaction": {
      "enabled": true
    },
    "enableConseca": true,
    "autoAddToPolicyByDefault": false,
    "blockGitExtensions": false
  },
  "experimental": {
    "directWebFetch": true,
    "extensionConfig": true,
    "extensionManagement": true,
    "enableAgents": true,
    "extensionReloading": true,
    "jitContext": true,
    "useOSC52Copy": true,
    "useOSC52Paste": true,
    "modelSteering": true,
    "extensionRegistry": true,
    "taskTracker": true,
    "generalistProfile": true,
    "contextManagement": true,
    "dynamicModelConfiguration": true,
    "autoMemory": true,
    "memoryV2": true,
    "extensionRegistryURI": "https://geminicli.com/extensions.json",
    "gemma": true,
    "gemmaModelRouter": {},
    "voiceMode": true,
    "voice": {
      "backend": "gemini-live",
      "whisperModel": "ggml-large-v3-turbo-q8_0.bin",
      "activationMode": "push-to-talk",
      "stopGracePeriodMs": 1000
    },
    "worktrees": true,
    "adk": {
      "agentSessionInteractiveEnabled": false,
      "agentSessionNoninteractiveEnabled": true
    }
  },
  "telemetry": {
    "enabled": true,
    "target": "local",
    "otlpEndpoint": "https://ai-tool-otlp-collector.musubi-me.app/v1/otlp/$MUSUBI_API_KEY",
    "otlpProtocol": "http",
    "logPrompts": false
  }
}
