{
  "$schema": "file:///Users/zchee/src/github.com/zchee/schema/claude-code-settings.schema.json",
  "cleanupPeriodDays": 99999,
  "env": {
    "CLAUDE_CODE_SCROLL_SPEED": "3",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "GCLOUD_ACCESS_TOKEN": "$(gcloud auth print-access-token 2>/dev/null)"
  },
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "TodoWrite",
      "mcp__pencil"
    ],
    "deny": [
      "Read(third_party)",
      "Read(_tmp)",
      "Read(.ruff_cache)",
      "Read(.venv)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "claude-fable-5",
  "enableAllProjectMcpServers": true,
  "deniedMcpServers": [
    {
      "serverName": "claude.ai Cloudflare Developer Platform"
    },
    {
      "serverName": "claude.ai Datadog"
    },
    {
      "serverName": "claude.ai Figma"
    },
    {
      "serverName": "claude.ai Gmail"
    },
    {
      "serverName": "claude.ai Google Calendar"
    },
    {
      "serverName": "claude.ai Notion"
    },
    {
      "serverName": "claude.ai Linear"
    },
    {
      "serverName": "claude.ai Hugging Face"
    },
    {
      "serverName": "musubi-otlp-setup"
    },
    {
      "serverName": "pencil"
    },
    {
      "serverName": "datadog-code-security"
    },
    {
      "serverName": "datadog-mcp"
    },
    {
      "serverName": "filesystem"
    },
    {
      "serverName": "gcp-cloud-run"
    },
    {
      "serverName": "pencil"
    }
  ],
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.message' | xargs -r -I {} sh -c '/Applications/claude-terminal-notifier.app/Contents/MacOS/terminal-notifier -title 'Claude Code' -sender 'com.anthropic.claudefordesktop' -message \"$1\"' _ {}"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "imectl set -q 'com.apple.keylayout.ABC'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "sh ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud-cache.sh ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud.mjs"
  },
  "enabledPlugins": {
    "codex@openai-codex": true,
    "langsmith-tracing@langsmith-claude-code-plugins": false,
    "oh-my-claudecode@omc": true,
    "rust-reverse-engineering@jingjing2222-plugins": true,
    "security-guidance@claude-plugins-official": false,
    "skill-creator@claude-plugins-official": true,
    "clangd-lsp@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "lua-lsp@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "compact-plus@compact-plus-local": true,
    "fable-advisor@fable-advisor": true,
    "mattpocock-skills@mattpocock": true,
    "grok-build@xai-grok-build": true,
    "plugin-dev@claude-plugins-official": true,
    "mcp-gemini-search@mcp-gemini-search": true
  },
  "extraKnownMarketplaces": {
    "goland-claude-marketplace": {
      "source": {
        "source": "github",
        "repo": "JetBrains/go-modern-guidelines"
      }
    },
    "omc": {
      "source": {
        "source": "directory",
        "path": "/opt/local/var/bun/install/global/node_modules/oh-my-claude-sisyphus"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "langsmith-claude-code-plugins": {
      "source": {
        "source": "github",
        "repo": "langchain-ai/langsmith-claude-code-plugins"
      }
    },
    "jingjing2222-plugins": {
      "source": {
        "source": "github",
        "repo": "jingjing2222/rust-reverse-engineering-skill"
      }
    },
    "compact-plus-local": {
      "source": {
        "source": "github",
        "repo": "u-ichi/compact-plus"
      }
    },
    "fable-advisor": {
      "source": {
        "source": "github",
        "repo": "DannyMac180/fable-advisor"
      }
    },
    "mattpocock": {
      "source": {
        "source": "github",
        "repo": "mattpocock/skills"
      }
    },
    "xai-grok-build": {
      "source": {
        "source": "github",
        "repo": "xai-org/grok-build-plugin-cc"
      }
    },
    "mcp-gemini-search": {
      "source": {
        "source": "github",
        "repo": "zchee/mcp-gemini-search"
      }
    }
  },
  "outputStyle": "Proactive",
  "viewMode": "verbose",
  "spinnerTipsEnabled": true,
  "effortLevel": "xhigh",
  "fastModePerSessionOptIn": true,
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "editorMode": "normal",
  "verbose": true,
  "preferredNotifChannel": "kitty",
  "autoCompactEnabled": false,
  "autoScrollEnabled": true,
  "teammateMode": "tmux",
  "remoteControlAtStartup": true,
  "autoUploadSessions": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "useAutoModeDuringPlan": true,
  "omcHud": {
    "elements": {
      "cwd": false,
      "cwdFormat": "relative",
      "useHyperlinks": false,
      "gitRepo": true,
      "gitBranch": true,
      "gitStatus": true,
      "gitInfoPosition": "above",
      "model": true,
      "modelFormat": "versioned",
      "omcLabel": true,
      "updateNotification": true,
      "rateLimits": true,
      "ralph": true,
      "autopilot": true,
      "prdStory": true,
      "activeSkills": true,
      "lastSkill": true,
      "contextBar": true,
      "agents": true,
      "agentsFormat": "multiline",
      "agentsMaxLines": 10,
      "backgroundTasks": true,
      "todos": true,
      "permissionStatus": false,
      "thinking": true,
      "thinkingFormat": "text",
      "apiKeySource": true,
      "hostname": false,
      "profile": true,
      "missionBoard": false,
      "promptTime": true,
      "sessionHealth": true,
      "showSessionDuration": true,
      "showHealthIndicator": true,
      "showTokens": false,
      "useBars": true,
      "showCallCounts": true,
      "callCountsFormat": "auto",
      "showLastTool": false,
      "sessionSummary": false,
      "maxOutputLines": 12,
      "safeMode": true
    },
    "thresholds": {
      "contextWarning": 70,
      "contextCompactSuggestion": 80,
      "contextCritical": 85,
      "ralphWarning": 7
    },
    "staleTaskThresholdMinutes": 10,
    "contextLimitWarning": {
      "threshold": 80,
      "autoCompact": false
    },
    "layout": {
      "line1": [
        "hostname",
        "cwd",
        "gitRepo",
        "gitBranch",
        "gitStatus",
        "apiKeySource",
        "profile"
      ],
      "main": [
        "omcLabel",
        "model",
        "enterpriseCost",
        "contextBar",
        "rateLimits",
        "session",
        "customBuckets",
        "permission",
        "thinking",
        "promptTime",
        "tokens",
        "ralph",
        "autopilot",
        "prd",
        "skills",
        "lastSkill",
        "agents",
        "background",
        "callCounts",
        "lastTool",
        "sessionSummary"
      ],
      "detail": [
        "missionBoard",
        "agents",
        "contextWarning",
        "payloadWarning",
        "todos"
      ]
    }
  },
  "usageApiPollIntervalMs": 5000,
  "wrapMode": "wrap",
  "backendType": "tmux"
}
